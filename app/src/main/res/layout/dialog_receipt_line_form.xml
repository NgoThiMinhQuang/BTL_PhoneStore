<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/receipt_select_product"
        android:textColor="@color/admin_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spProduct"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_edittext_admin"
        android:paddingStart="14dp"
        android:paddingEnd="14dp" />

    <TextView
        android:id="@+id/tvReceiptLineEmptyMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/receipt_no_products_available"
        android:textColor="@color/admin_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/receipt_quantity_label"
        android:textColor="@color/admin_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtReceiptLineQuantity"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edittext_admin"
        android:hint="@string/receipt_line_quantity_hint"
        android:inputType="number"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="1"
        android:textColor="@color/admin_text_primary"
        android:textColorHint="@color/admin_text_secondary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/receipt_unit_cost_label"
        android:textColor="@color/admin_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtReceiptLineUnitCost"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edittext_admin"
        android:hint="@string/receipt_line_unit_cost_hint"
        android:inputType="number"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="@color/admin_text_primary"
        android:textColorHint="@color/admin_text_secondary" />
</LinearLayout>

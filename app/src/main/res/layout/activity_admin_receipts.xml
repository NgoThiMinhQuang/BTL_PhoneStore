<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_red_height"
            android:background="@drawable/bg_toolbar_admin"
            android:elevation="4dp" />

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@android:color/transparent"
            android:elevation="16dp"
            android:gravity="center_vertical"
            android:minHeight="88dp"
            android:paddingStart="18dp"
            android:paddingEnd="12dp"
            android:translationZ="16dp"
            app:contentInsetStartWithNavigation="0dp"
            app:titleMargin="0dp"
            app:titleTextColor="@android:color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="76dp"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:elevation="8dp"
            android:orientation="vertical"
            android:translationZ="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="16dp"
                android:elevation="12dp"
                android:translationZ="12dp"
                app:cardBackgroundColor="@color/admin_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/admin_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/receipt_list_header_title"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtReceiptSearch"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_edittext_admin"
                            android:drawableStart="@drawable/ic_search_small"
                            android:drawablePadding="10dp"
                            android:hint="@string/receipt_search_hint"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:singleLine="true"
                            android:textColor="@color/admin_text_primary"
                            android:textColorHint="@color/admin_text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddReceipt"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginStart="12dp"
                            android:contentDescription="@string/receipt_create"
                            app:backgroundTint="@color/admin_primary"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_plus"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconTint="@android:color/white" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutReceiptFilters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvReceiptResultCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="16dp"
                android:text="Hiển thị 0 phiếu nhập"
                android:textColor="@color/admin_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReceipts"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingTop="0dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp" />
        </LinearLayout>
    </FrameLayout>

    <include layout="@layout/view_admin_bottom_bar" />
</LinearLayout>

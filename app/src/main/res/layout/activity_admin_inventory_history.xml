<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_red_height"
            android:background="@drawable/bg_toolbar_admin" />

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@android:color/transparent"
            android:elevation="16dp"
            android:gravity="center_vertical"
            android:minHeight="88dp"
            android:paddingStart="18dp"
            android:paddingEnd="12dp"
            android:translationZ="16dp"
            app:contentInsetStartWithNavigation="0dp"
            app:titleMargin="0dp"
            app:titleTextColor="@android:color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="76dp"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:elevation="8dp"
            android:orientation="vertical"
            android:translationZ="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_panel_admin"
                android:elevation="12dp"
                android:translationZ="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_history_title"
                    android:textColor="@color/admin_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spHistoryProduct"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edittext_admin"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:spinnerMode="dropdown" />

                    <Spinner
                        android:id="@+id/spHistoryType"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edittext_admin"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:spinnerMode="dropdown" />
                </LinearLayout>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvInventoryHistory"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingTop="0dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp" />
        </LinearLayout>
    </FrameLayout>

    <include layout="@layout/view_admin_bottom_bar" />
</LinearLayout>

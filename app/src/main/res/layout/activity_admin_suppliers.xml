<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/supplier_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_red_height"
            android:background="@drawable/bg_toolbar_supplier"
            android:elevation="4dp" />

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            android:paddingStart="18dp"
            android:paddingEnd="12dp"
            app:contentInsetStartWithNavigation="0dp"
            app:titleTextColor="@android:color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/header_admin_content_offset"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="@dimen/header_panel_pull_up"
                android:layout_marginEnd="16dp"
                android:elevation="6dp"
                app:cardBackgroundColor="@color/admin_surface"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/supplier_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtSupplierSearch"
                            android:layout_width="0dp"
                            android:layout_height="58dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_edittext_supplier"
                            android:drawableStart="@drawable/ic_search_small"
                            android:drawablePadding="10dp"
                            android:hint="@string/supplier_search_hint"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:singleLine="true"
                            android:textColor="@color/admin_text_primary"
                            android:textColorHint="@color/admin_text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddSupplier"
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:layout_marginStart="12dp"
                            android:contentDescription="@string/add_supplier"
                            app:backgroundTint="@color/supplier_primary"
                            app:cornerRadius="22dp"
                            app:icon="@drawable/ic_plus"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconTint="@android:color/white" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSuppliers"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="14dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingTop="0dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp" />
        </LinearLayout>
    </FrameLayout>

    <include layout="@layout/view_admin_bottom_bar" />
</LinearLayout>

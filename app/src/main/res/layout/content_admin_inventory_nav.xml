<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel_admin"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_inventory_title"
                android:textColor="@color/admin_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/admin_inventory_nav_summary"
                android:textColor="@color/admin_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenInventoryOverview"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="@string/admin_inventory_overview"
            android:textAllCaps="false"
            android:textColor="@color/admin_text_primary"
            app:backgroundTint="@color/admin_surface"
            app:cornerRadius="20dp"
            app:strokeColor="@color/admin_stroke"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenReceipts"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/admin_inventory_receipts"
            android:textAllCaps="false"
            android:textColor="@color/admin_text_primary"
            app:backgroundTint="@color/admin_surface"
            app:cornerRadius="20dp"
            app:strokeColor="@color/admin_stroke"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenSuppliers"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/admin_inventory_suppliers"
            android:textAllCaps="false"
            android:textColor="@color/admin_text_primary"
            app:backgroundTint="@color/admin_surface"
            app:cornerRadius="20dp"
            app:strokeColor="@color/admin_stroke"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenAlerts"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/admin_inventory_alerts"
            android:textAllCaps="false"
            android:textColor="@color/admin_text_primary"
            app:backgroundTint="@color/admin_surface"
            app:cornerRadius="20dp"
            app:strokeColor="@color/admin_stroke"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenHistory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/admin_inventory_history"
            android:textAllCaps="false"
            android:textColor="@color/admin_text_primary"
            app:backgroundTint="@color/admin_surface"
            app:cornerRadius="20dp"
            app:strokeColor="@color/admin_stroke"
            app:strokeWidth="1dp" />
    </LinearLayout>
</ScrollView>

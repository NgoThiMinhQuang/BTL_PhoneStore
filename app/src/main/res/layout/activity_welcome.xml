<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/ivWelcome"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/welcome_hero_content_desc"
        android:scaleType="fitCenter"
        android:src="@drawable/drawable_welcome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="WELCOME TO PHONE STORE"
        android:textColor="@color/red_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Khám phá sản phẩm &amp; dịch vụ của chúng tôi"
        android:textColor="@color/text_sub"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/heroOverlay"
        android:layout_width="344dp"
        android:layout_height="341dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSub"
        app:layout_constraintVertical_bias="0.34">

        <ImageView
            android:id="@+id/bubbleColors"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginStart="28dp"
            android:layout_marginTop="52dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/welcome_feature_colors_desc"
            android:elevation="10dp"
            android:src="@drawable/ic_mau_moi"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/bubbleRepair"
            android:layout_width="102dp"
            android:layout_height="102dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="4dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/welcome_feature_repair_desc"
            android:elevation="10dp"
            android:src="@drawable/ic_sua_chua_nhanh"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/bubbleSale"
            android:layout_width="80dp"
            android:layout_height="90dp"
            android:layout_marginTop="148dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/welcome_feature_sale_desc"
            android:elevation="10dp"
            android:src="@drawable/ic_uu_dai_khung"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/bubbleDelivery"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_marginTop="140dp"
            android:layout_marginEnd="4dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/welcome_feature_delivery_desc"
            android:elevation="10dp"
            android:src="@drawable/ic_giao_hang"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/bubbleSupport"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_marginTop="238dp"
            android:layout_marginEnd="44dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/welcome_feature_support_desc"
            android:elevation="10dp"
            android:src="@drawable/ic_ho_tro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/dotTopLeft"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="126dp"
            android:alpha="0.96"
            android:background="@drawable/bg_welcome_dot_red"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/dotTopRight"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="124dp"
            android:layout_marginEnd="6dp"
            android:alpha="0.96"
            android:background="@drawable/bg_welcome_dot_red"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/dotMidLeft"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="96dp"
            android:layout_marginTop="150dp"
            android:alpha="0.85"
            android:background="@drawable/bg_welcome_dot_teal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/dotMidRight"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginTop="218dp"
            android:layout_marginEnd="68dp"
            android:alpha="0.85"
            android:background="@drawable/bg_welcome_dot_teal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="100dp"
        android:background="@drawable/bg_panel"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="ĐĂNG NHẬP"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/red_primary"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoRegister"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="ĐĂNG KÝ"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/red_dark"
            app:cornerRadius="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="Quản lý điện thoại, hóa đơn và khách hàng dễ dàng."
            android:textColor="@color/text_sub"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
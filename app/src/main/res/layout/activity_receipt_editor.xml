<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/admin_background"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_toolbar_admin"
        app:titleTextColor="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <Spinner
            android:id="@+id/spSupplier"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <EditText
            android:id="@+id/edtReceiptNote"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_edittext_admin"
            android:gravity="top|start"
            android:hint="@string/receipt_note"
            android:padding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddReceiptLine"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/receipt_add_line"
            android:textAllCaps="false"
            app:backgroundTint="@color/admin_surface"
            app:strokeColor="@color/admin_stroke"
            app:strokeWidth="1dp"
            app:cornerRadius="18dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReceiptLines"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveReceipt"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="16dp"
        android:text="@string/receipt_save"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/admin_primary"
        app:cornerRadius="24dp" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/admin_surface" />
            <stroke
                android:width="1.6dp"
                android:color="@color/admin_primary" />
            <corners android:radius="18dp" />
            <padding
                android:left="14dp"
                android:top="10dp"
                android:right="14dp"
                android:bottom="10dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/admin_surface_soft" />
            <stroke
                android:width="1.2dp"
                android:color="@color/admin_primary" />
            <corners android:radius="18dp" />
            <padding
                android:left="14dp"
                android:top="10dp"
                android:right="14dp"
                android:bottom="10dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/admin_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/admin_stroke" />
            <corners android:radius="18dp" />
            <padding
                android:left="14dp"
                android:top="10dp"
                android:right="14dp"
                android:bottom="10dp" />
        </shape>
    </item>
</selector>

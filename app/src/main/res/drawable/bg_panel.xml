<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="@color/panel_light"
        android:endColor="@color/panel_soft" />

    <stroke
        android:width="1dp"
        android:color="@color/panel_stroke" />

    <corners android:radius="18dp" />

    <!-- GIỮ padding để các thẻ bg_panel khỏi bị sát chữ -->
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp" />
</shape>

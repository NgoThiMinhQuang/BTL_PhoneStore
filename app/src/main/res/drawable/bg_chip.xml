<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/panel_soft" />
            <stroke android:width="1.6dp" android:color="@color/red_primary" />
            <corners android:radius="999dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/white" />
            <stroke android:width="1dp" android:color="@color/panel_stroke" />
            <corners android:radius="999dp" />
        </shape>
    </item>

</selector>
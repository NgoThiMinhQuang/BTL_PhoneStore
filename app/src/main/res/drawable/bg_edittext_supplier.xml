<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/admin_surface" />
            <stroke
                android:width="1.6dp"
                android:color="@color/supplier_primary" />
            <corners android:radius="20dp" />
            <padding
                android:left="16dp"
                android:top="12dp"
                android:right="16dp"
                android:bottom="12dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/supplier_surface_soft" />
            <stroke
                android:width="1.2dp"
                android:color="@color/supplier_primary" />
            <corners android:radius="20dp" />
            <padding
                android:left="16dp"
                android:top="12dp"
                android:right="16dp"
                android:bottom="12dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/admin_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/supplier_stroke" />
            <corners android:radius="20dp" />
            <padding
                android:left="16dp"
                android:top="12dp"
                android:right="16dp"
                android:bottom="12dp" />
        </shape>
    </item>
</selector>

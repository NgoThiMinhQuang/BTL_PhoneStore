<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/admin_surface_soft" />
                    <stroke android:width="1.2dp" android:color="@color/admin_primary" />
                    <corners android:radius="18dp" />
                    <padding
                        android:left="14dp"
                        android:top="0dp"
                        android:right="42dp"
                        android:bottom="0dp" />
                </shape>
            </item>

            <item
                android:width="18dp"
                android:height="18dp"
                android:drawable="@drawable/ic_chevron_down"
                android:gravity="end|center_vertical"
                android:right="14dp" />
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="@color/admin_surface" />
                    <stroke android:width="1dp" android:color="@color/admin_stroke" />
                    <corners android:radius="18dp" />
                    <padding
                        android:left="14dp"
                        android:top="0dp"
                        android:right="42dp"
                        android:bottom="0dp" />
                </shape>
            </item>

            <item
                android:width="18dp"
                android:height="18dp"
                android:drawable="@drawable/ic_chevron_down"
                android:gravity="end|center_vertical"
                android:right="14dp" />
        </layer-list>
    </item>
</selector>
